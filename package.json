{
  "name": "@huo15/wecom",
  "version": "2.8.17",
  "description": "OpenClaw 企业微信（WeCom）插件 v2.8.17 — 长任务结果回流修复 + 进度反馈可配置：bot-ws 在 reqId 失效（errcode 846605）/ 流过期（846608）时不再短路 onFail 丢消息，而是降级到 sendMessage 主动推送 + Agent API 两层 fallback；新增 channels.wecom.bot.progressMode（progress/heartbeat/delayed/off，默认 progress）让长任务期间显示阶段化文案。继承 v2.8.16 enhance share 兜底、v2.8.14 bot-webhook long-task rescue。默认 Bot WebSocket，支持加密媒体解密、Agent 主动发消息、微信客服接入与多账号切换。",
  "license": "ISC",
  "author": "YanHaidao (VX: YanHaidao)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YanHaidao/wecom.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@wecom/aibot-node-sdk": "^1.0.0",
    "fast-xml-parser": "5.3.4",
    "undici": "^7.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "npm run typecheck"
  },
  "peerDependencies": {
    "openclaw": "^2026.3.23-2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.4.27"
    },
    "channel": {
      "id": "wecom",
      "label": "WeCom (企业微信)",
      "selectionLabel": "WeCom (企业微信)",
      "detailLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "docsLabel": "企业微信",
      "blurb": "企业微信官方推荐三方插件，默认 Bot WS 配置简单，支持主动发消息与 Agent 全能力。",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx",
        "企微",
        "企业微信"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@huo15/wecom",
      "localPath": "extensions/wecom",
      "defaultChoice": "npm"
    }
  }
}
