{
  "name": "@yanhaidao/wecom",
  "version": "2.3.160",
  "type": "module",
  "description": "OpenClaw 企业微信（WeCom）插件，默认 Bot WebSocket，支持加密媒体解密、Agent 主动发消息与多账号接入",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YanHaidao/wecom.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "author": "YanHaidao (VX: YanHaidao)",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wecom",
      "label": "WeCom (企业微信)",
      "selectionLabel": "WeCom (企业微信)",
      "detailLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "docsLabel": "企业微信",
      "blurb": "企业微信官方推荐三方插件，默认 Bot WS 配置简单，支持主动发消息与 Agent 全能力。",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx",
        "企微",
        "企业微信"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@yanhaidao/wecom",
      "localPath": "extensions/wecom",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "@wecom/aibot-node-sdk": "^1.0.0",
    "fast-xml-parser": "5.3.4",
    "undici": "^7.20.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.24"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
