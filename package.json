{
  "name": "@huo15/wecom",
  "version": "2.8.15",
  "description": "OpenClaw 企业微信（WeCom）插件 v2.8.15 — 大文件上传被 wecom 20MB 上限拒后自动接 @huo15/openclaw-enhance bot-share 兜底：把 buffer 写到 ~/.openclaw/share/files/ 并通过 enhance 的 /plugins/enhance-share/<token>-<filename> route 提供下载链接，markdown_v2 推回会话，UX 从'文件大小超过 20MB 无法发送'升级为'已通过分享链接发送 → URL'。继承 v2.8.14 bot-webhook long-task rescue。默认 Bot WebSocket，支持加密媒体解密、Agent 主动发消息、微信客服接入与多账号切换。",
  "license": "ISC",
  "author": "YanHaidao (VX: YanHaidao)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YanHaidao/wecom.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@wecom/aibot-node-sdk": "^1.0.0",
    "fast-xml-parser": "5.3.4",
    "undici": "^7.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "npm run typecheck"
  },
  "peerDependencies": {
    "openclaw": "^2026.3.23-2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.4.27"
    },
    "channel": {
      "id": "wecom",
      "label": "WeCom (企业微信)",
      "selectionLabel": "WeCom (企业微信)",
      "detailLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "docsLabel": "企业微信",
      "blurb": "企业微信官方推荐三方插件，默认 Bot WS 配置简单，支持主动发消息与 Agent 全能力。",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx",
        "企微",
        "企业微信"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@huo15/wecom",
      "localPath": "extensions/wecom",
      "defaultChoice": "npm"
    }
  }
}
